#!/usr/bin/python3 -u
# RSSBOT - displays feeds in your IRC channel
#
#

import sys, os ; sys.path.insert(0, os.getcwd())

from bot.csl import execute
from bot.krn import k
from bot.prs import parse_cli

def main():
    c = parse_cli()
    c.wd = c.wd or os.path.expanduser("~/.rssbot")
    if c.txt:
        k.walk("bot")
        return k.cmd(c.origtxt)
    if c.mods:
        k.start()
        k.init(c.mods)
        k.wait()

execute(main)
