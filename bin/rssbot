#!/usr/bin/python3 -u
# RSSBOT - display feeds in your IRC channel
#
#

from bot.spc import execute, get, k , parse_cli

def main():
    c = parse_cli("rssbot")
    if get(c, "txt", None):
        k.walk("bot")
        k.load_mod("rssbot")
        return k.cmd(c.origtxt)
    k.start()
    k.init("irc,rssbot,cmd")
    if "s" in c.opts:
        k.init("csl")
    k.wait()

execute(main)
