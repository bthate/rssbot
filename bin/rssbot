#!/usr/bin/python3 -u
# RSSBOT - display feeds in your IRC channel
#
#

import bot.obj, os

from bot.csl import execute
from bot.krn import k
from bot.obj import get, tojson
from bot.prs import parse_cli

def main():
    c = parse_cli("rssbot")
    if get(c, "txt"):
        k.walk("bot")
        return k.cmd(c.origtxt)
    k.start()
    k.init("irc,rss,csl,cmd,ent,opr")
    k.wait()

execute(main)
