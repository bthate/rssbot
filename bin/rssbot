#!/usr/bin/python3 -u

import os, sys ; sys.path.insert(0, os.getcwd())

from ob.err import EINIT
from ob.shl import daemon, execute, parse_cli
from obot import __version__

from ob import k

def main():
    parse_cli("rssbot", __version__)
    k.cfg.prompting = True
    k.cfg.modules += "irc,rss,cmds"
    k.cfg.nousers = True
    try:
        k.init(k.cfg.modules)
    except EINIT:
        print("rssbot <localhost> <channel> <nick>")
        return
    k.start()
    k.wait()

execute(main)
os._exit(0)
