#!/usr/bin/python3

from ol.spc import Console, boot, cmd, execute, ol, os, scandir
from bot.irc import IRC

def main():
    k = boot("rssbot")
    if "b" in k.cfg.opts:
        print("RSSBOT started at %s" % time.ctime(time.time()))
        print(ol.format(k.cfg))
    scandir(k.cfg.wd)
    k.walk("bot,botmod,rssbot")
    if k.cfg.txt:
        return cmd(k.cfg.otxt)
    k.start()
    k.init(k.cfg.mods)
    i = IRC()
    i.start()
    c = Console()
    c.start()
    k.wait()
         
execute(main)
os._exit(0)
