#!/usr/bin/python3 -u
# RSSBOT - display feeds in your IRC channel
#
#

from bot.spc import execute, get, k , parse_cli

def main():
    c = parse_cli("rssbot")
    if get(c, "txt", None):
        k.walk("bot")
        return k.cmd(c.origtxt)
    k.start()
    k.init("irc,bot.rss,csl,shw")
    k.wait()

execute(main)
